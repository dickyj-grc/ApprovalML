# ApprovalML Standalone Runtime — copy to .env and fill in values
#
# Quick start:
#   cp .env.example .env
#   docker compose up

# ── Security ──────────────────────────────────────────────────────────────────
# Token required by the MCP client. Generate with: openssl rand -hex 32
# Leave blank to disable auth (development only).
APPROVALML_API_TOKEN=

# ── Database ──────────────────────────────────────────────────────────────────
# Password for the local PostgreSQL container (managed by docker-compose).
POSTGRES_PASSWORD=approvalml

# ── Public URL ────────────────────────────────────────────────────────────────
# The URL shown in approval email links. Must be reachable by the approver.
# For local testing, use http://localhost:8765.
# For production, set to your public domain: https://approvals.your-company.com
APPROVALML_SERVER_URL=http://localhost:8765

# ── Port ─────────────────────────────────────────────────────────────────────
RUNTIME_PORT=8765

# ── Workflow preload ───────────────────────────────────────────────────────────
# Host path to a directory of *.yaml files to load into the DB on startup.
# Leave blank to skip (workflows can still be registered via the API).
WORKFLOWS_DIR_HOST=./workflows

# ── SMTP (optional) ───────────────────────────────────────────────────────────
# Leave SMTP_HOST blank to print approval emails to Docker logs instead of sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=no-reply@example.com
EMAIL_FROM_NAME=ApprovalML
